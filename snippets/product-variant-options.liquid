{% comment %}
  Renders product variant options con clases estructurales de Dawn para activar el JavaScript
{% endcomment %}

{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- for value in option.values -%}
  {%- liquid
    # 1. Buscamos la foto de la variante real para este valor de color
    assign variant_image_url = null
    for variant in product.variants
      if variant.options contains value and variant.image
        assign variant_image_url = variant.image | image_url: width: 120, height: 120, crop: 'center'
        break
      endif
    endfor

    assign option_disabled = true
    if value.available
      assign option_disabled = false
    endif
  -%}

  <input
    type="radio"
    id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
    name="{{ option.name }}"
    value="{{ value | escape }}"
    form="{{ product_form_id }}"
    {% if value.selected %}
      checked
    {% endif %}
    class="{% if option_disabled %}disabled{% endif %} product-form__input"
    style="position: absolute !important; opacity: 0 !important; width: 1px !important; height: 1px !important; z-index: -1 !important;"
  >
  
  <label
    for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
    style="
      {% if variant_image_url %}
        background-image: url('{{ variant_image_url }}') !important;
        background-size: cover !important;
        background-position: center !important;
        background-repeat: no-repeat !important;
        width: 54px !important;
        height: 54px !important;
        text-indent: -9999px !important;
        overflow: hidden !important;
      {% else %}
        padding: 10px 20px !important;
      {% endif %}
      display: inline-block !important;
      border: 1.5px solid #e2e8f0 !important;
      border-radius: 8px !important;
      cursor: pointer !important;
      margin: 4px !important;
      transition: border-color 0.15s ease;
    "
  >
    {{ value }}
  </label>
{%- endfor -%}