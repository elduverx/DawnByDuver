{% comment %}
  Renders product variant options respetando las muestras nativas de Dawn para no romper el JS
{% endcomment %}

{%- liquid
  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- for value in option.values -%}
  {%- liquid
    # 1. Buscamos la foto de la variante real para este valor de color
    assign variant_image_url = null
    for variant in product.variants
      if variant.options contains value and variant.image
        assign variant_image_url = variant.image | image_url: width: 120, height: 120, crop: 'center'
        break
      endif
    endfor

    # 2. Respetamos las variables nativas del tema Dawn para que funcione el JavaScript
    assign swatch_value = null
    if variant_image_url
      assign swatch_value = 'url(' | append: variant_image_url | append: ')'
    elsif value.swatch.image
      assign image_url = value.swatch.image | image_url: width: 50
      assign swatch_value = 'url(' | append: image_url | append: ')'
    elsif value.swatch.color
      assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
    endif

    assign option_disabled = true
    if value.available
      assign option_disabled = false
    endif
  -%}

  {%- if block.settings.picker_type == 'button' and value.swatch != null -%}
    <input
      type="radio"
      id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
      name="{{ option.name }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      {% if value.selected %}
        checked
      {% endif %}
      {% if option_disabled %}
        class="disabled"
      {% endif %}
    >
    <label
      for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
      class="product-form__swatch"
      style="
        {% if swatch_value %}
          --swatch-background: {{ swatch_value }} !important;
        {% endif %}
        width: 54px !important;
        height: 54px !important;
        border-radius: 8px !important; /* Cuadrados del competidor */
      "
    >
      <span class="visually-hidden">{{ value }}</span>
    </label>
  {%- else -%}
    <input
      type="radio"
      id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
      name="{{ option.name }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      {% if value.selected %}
        checked
      {% endif %}
      {% if option_disabled %}
        class="disabled"
      {% endif %}
    >
    <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
      {{ value -}}
    </label>
  {%- endif -%}
{%- endfor -%}