{% comment %}
  Renders a swatch component.
  Accepts:
  - swatch: {Object} a swatch object
  - shape: {String} swatch shape. Accepts 'square', defaults to circle.

  Usage:
  {% render 'swatch',
    swatch: value.swatch
    shape: 'square'
  %}
{% endcomment %}

{%- liquid
  assign swatch_value = null
  
  # 1. Intentamos buscar la imagen real de la variante del producto actual
  if product
    for variant in product.variants
      if variant.options contains value and variant.image
        assign swatch_value = variant.image | image_url: width: 120, height: 120, crop: 'center'
        break
      endif
    endfor
  endif

  # 2. Si no la encuentra, recurre al sistema nativo por si acaso
  if swatch_value == null
    if swatch.image
      assign swatch_value = swatch.image | image_url: width: 50
    elsif swatch.color
      assign swatch_value = 'rgb(' | append: swatch.color.rgb | append: ')'
    endif
  endif
-%}

<span
  {% if swatch_value %}
    class="swatch swatch--square"
    style="
      background-image: url('{{ swatch_value }}') !important;
      background-size: cover !important;
      background-position: center !important;
      background-repeat: no-repeat !important;
      width: 54px !important;
      height: 54px !important;
      border-radius: 8px !important; /* Bordes redondeados del competidor */
      display: inline-block !important;
      border: 1.5px solid #e2e8f0 !important;
    "
  {% else %}
    class="swatch{% if shape == 'square' %} swatch--square{% endif %}"
  {% endif %}
></span>