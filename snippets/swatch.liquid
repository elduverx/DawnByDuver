{%- liquid
  assign swatch_value = null
  
  # Buscamos en el producto global la variante que coincida con el valor actual de este color
  if product
    for variant in product.variants
      if variant.options contains value and variant.image
        assign swatch_value = variant.image | image_url: width: 120, height: 120, crop: 'center'
        break
      endif
    endfor
  endif

  # Si por algún motivo no encuentra foto de ropa, usa el sistema nativo de color plano
  if swatch_value == null
    if swatch.image
      assign swatch_value = swatch.image | image_url: width: 50
    elsif swatch.color
      assign swatch_value = 'rgb(' | append: swatch.color.rgb | append: ')'
    endif
  endif
-%}

<span
  class="swatch swatch--square"
  style="
    {% if swatch_value contains 'http' or swatch_value contains '//cdn' %}
      background-image: url('{{ swatch_value }}') !important;
      background-size: cover !important;
      background-position: center !important;
      background-repeat: no-repeat !important;
    {% else %}
      background-color: {{ swatch_value }} !important;
    {% endif %}
    width: 100% !important;
    height: 100% !important;
    display: inline-block !important;
  "
></span>