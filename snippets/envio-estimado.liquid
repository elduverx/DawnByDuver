{%- assign mes_num = 'now' | date: '%-m' | plus: 0 -%}
{%- assign mes_manana_num = 'now' | date: '%s' | plus: 86400 | date: '%-m' | plus: 0 -%}
{%- assign mes_enviado_num = 'now' | date: '%s' | plus: 172800 | date: '%-m' | plus: 0 -%}

{%- assign dia_hoy = 'now' | date: '%-d' -%}
{%- assign dia_manana = 'now' | date: '%s' | plus: 86400 | date: '%-d' -%}
{%- assign dia_enviado = 'now' | date: '%s' | plus: 172800 | date: '%-d' -%}

{%- assign meses = 'Ene,Feb,Mar,Abr,May,Jun,Jul,Ago,Sep,Oct,Nov,Dic' | split: ',' -%}

{%- assign idx_hoy = mes_num | minus: 1 -%}
{%- assign idx_manana = mes_manana_num | minus: 1 -%}
{%- assign idx_enviado = mes_enviado_num | minus: 1 -%}

{%- assign mes_hoy = meses[idx_hoy] -%}
{%- assign mes_manana = meses[idx_manana] -%}
{%- assign mes_enviado = meses[idx_enviado] -%}

<div style="margin-top: 16px; padding: 20px 0; border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb;">
  <svg width="100%" height="20" viewBox="0 0 300 20" preserveAspectRatio="xMidYMid meet">
    <line x1="50" y1="10" x2="250" y2="10" stroke="#121212" stroke-width="1.5"/>
    <circle cx="50" cy="10" r="5" fill="white" stroke="#121212" stroke-width="1.5"/>
    <circle cx="150" cy="10" r="5" fill="white" stroke="#121212" stroke-width="1.5"/>
    <circle cx="250" cy="10" r="5" fill="white" stroke="#121212" stroke-width="1.5"/>
  </svg>
  <div style="display: flex; justify-content: space-between; text-align: center; margin-top: 8px;">
    <div style="flex: 1;">
      <p style="font-size: 1.1rem; letter-spacing: 0.15em; color: #121212; margin: 0 0 4px 0;">COMPRADO</p>
      <p style="font-size: 1.3rem; font-weight: 600; color: #121212; margin: 0;">{{ dia_hoy }} {{ mes_hoy }}</p>
    </div>
    <div style="flex: 1;">
      <p style="font-size: 1.1rem; letter-spacing: 0.15em; color: #121212; margin: 0 0 4px 0;">PROCESADO</p>
      <p style="font-size: 1.3rem; font-weight: 600; color: #121212; margin: 0;">{{ dia_hoy }} {{ mes_hoy }} / {{ dia_manana }} {{ mes_manana }}</p>
    </div>
    <div style="flex: 1;">
      <p style="font-size: 1.1rem; letter-spacing: 0.15em; color: #121212; margin: 0 0 4px 0;">ENVIADO</p>
      <p style="font-size: 1.3rem; font-weight: 600; color: #121212; margin: 0;">{{ dia_enviado }} {{ mes_enviado }}</p>
    </div>
  </div>
</div>

<div style="margin-top: 20px; padding: 20px; border: 1px solid #e5e7eb; font-family: 'Assistant', sans-serif;">
  <p style="font-size: 1.1rem; letter-spacing: 0.15em; color: #c9b99a; text-align: center; margin: 0 0 8px 0;">PROMOCIÓN ACTIVA</p>
  <h3 style="font-size: 2rem; font-weight: 400; text-align: center; margin: 0 0 8px 0; font-family: Georgia, serif; text-transform: none;">Descuento por cantidad en toda la web</h3>
  <p style="font-size: 1.3rem; color: #6b7280; text-align: center; margin: 0 0 20px 0;">Combina tus productos y ahorra más en tu pedido</p>
  <div style="display: flex; gap: 12px; margin-bottom: 20px;">
    <div style="flex: 1; border: 1px solid #e5e7eb; padding: 16px;">
      <p style="font-size: 1.2rem; color: #121212; margin: 0 0 4px 0;">2</p>
      <p style="font-size: 1.2rem; letter-spacing: 0.1em; color: #121212; margin: 0 0 12px 0;">UNIDADES</p>
      <p style="font-size: 2.4rem; font-weight: 400; font-family: Georgia, serif; margin: 0 0 8px 0;">−10%</p>
      <p style="font-size: 1.3rem; color: #121212; margin: 0;">Descuento</p>
    </div>
    <div style="flex: 1; border: 1px solid #e5e7eb; padding: 16px;">
      <p style="font-size: 1.2rem; color: #121212; margin: 0 0 4px 0;">3</p>
      <p style="font-size: 1.2rem; letter-spacing: 0.1em; color: #121212; margin: 0 0 12px 0;">UNIDADES</p>
      <p style="font-size: 2.4rem; font-weight: 400; font-family: Georgia, serif; margin: 0 0 8px 0;">−15%</p>
</div>