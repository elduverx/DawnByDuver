<div style="margin-top: 16px; padding: 20px 0; border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb;">
  <svg width="100%" height="20" viewBox="0 0 300 20" preserveAspectRatio="none">
    <line x1="50" y1="10" x2="250" y2="10" stroke="#121212" stroke-width="1.5"/>
    <circle cx="50" cy="10" r="5" fill="white" stroke="#121212" stroke-width="1.5"/>
    <circle cx="150" cy="10" r="5" fill="white" stroke="#121212" stroke-width="1.5"/>
    <circle cx="250" cy="10" r="5" fill="white" stroke="#121212" stroke-width="1.5"/>
  </svg>
  <div style="display: flex; justify-content: space-between; text-align: center; margin-top: 8px;">
    <div style="flex: 1;">
      <p style="font-size: 1.1rem; letter-spacing: 0.15em; color: #121212; margin: 0 0 4px 0;">COMPRADO</p>
      <p style="font-size: 1.3rem; font-weight: 600; color: #121212; margin: 0;" class="fecha-comprado"></p>
    </div>
    <div style="flex: 1;">
      <p style="font-size: 1.1rem; letter-spacing: 0.15em; color: #121212; margin: 0 0 4px 0;">PROCESADO</p>
      <p style="font-size: 1.3rem; font-weight: 600; color: #121212; margin: 0;" class="fecha-procesado"></p>
    </div>
    <div style="flex: 1;">
      <p style="font-size: 1.1rem; letter-spacing: 0.15em; color: #121212; margin: 0 0 4px 0;">ENVIADO</p>
      <p style="font-size: 1.3rem; font-weight: 600; color: #121212; margin: 0;" class="fecha-enviado"></p>
    </div>
  </div>
</div>

<script>
  var meses = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  var hoy = new Date();
  var manana = new Date(hoy); manana.setDate(hoy.getDate() + 1);
  var enviado = new Date(hoy); enviado.setDate(hoy.getDate() + 2);
  function fmt(d) { return d.getDate() + ' ' + meses[d.getMonth()]; }
  document.querySelector('.fecha-comprado').textContent = fmt(hoy);
  document.querySelector('.fecha-procesado').textContent = fmt(hoy) + ' / ' + fmt(manana);
  document.querySelector('.fecha-enviado').textContent = fmt(enviado);
</script>