          "settings": {
            "custom_liquid": "<div style=\"display: flex; justify-content: space-between; align-items: center; width: 100%; margin: 1.5rem 0 0.5rem 0; font-family: inherit;\">\n  <span style=\"font-size: 1.4rem; font-weight: 500; color: #121212; letter-spacing: 0.4px;\">Talla</span>\n  \n  <a href=\"#tabla-tallas-modal\" style=\"display: inline-flex; align-items: center; gap: 5px; font-size: 1.3rem; color: #121212; text-decoration: underline; font-weight: 400; cursor: pointer; background: none; border: none; padding: 0;\">\n    <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"transform: rotate(-45deg); display: inline-block; vertical-align: middle;\">\n      <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line>\n      <line x1=\"9\" y1=\"12\" x2=\"9\" y2=\"15\"></line>\n      <line x1=\"14\" y1=\"12\" x2=\"14\" y2=\"15\"></line>\n    </svg>\n    Tabla de tallas\n  </a>\n</div>\n\n{% comment %} Aquí se pintan tus botones dinámicos del panel {% endcomment %}\n<div id=\"contenedor-tallas-clon\" style=\"display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 1.5rem;\"></div>\n\n<script>\n(function() {\n  function cargarTallasDesdeShopify() {\n    var cajaBotones = document.getElementById('contenedor-tallas-clon');\n    if (!cajaBotones || cajaBotones.children.length > 0) return;\n\n    // Buscamos el elemento oculto o el select nativo donde Dawn guarda tus tallas\n    var selectNativo = document.querySelector('variant-selects select') || document.querySelector('.select__select') || document.querySelector('.product-form__input select');\n    \n    if (selectNativo && selectNativo.options) {\n      // Ocultamos la caja gris nativa si estuviera visible para que no se vea repetida\n      var contenedorGris = selectNativo.closest('.product-form__input--dropdown') || selectNativo.parentElement;\n      if (contenedorGris) contenedorGris.style.display = 'none';\n\n      for (var i = 0; i < selectNativo.options.length; i++) {\n        var textoTalla = selectNativo.options[i].text.trim();\n        var valorTalla = selectNativo.options[i].value.trim();\n\n        var btn = document.createElement('button');\n        btn.type = 'button';\n        btn.className = 'boton-talla-premium';\n        if (selectNativo.selectedIndex === i) {\n          btn.classList.add('is-active');\n        }\n        btn.setAttribute('data-value', valorTalla);\n        btn.textContent = textoTalla;\n\n        btn.onclick = function() {\n          cajaBotones.querySelectorAll('.boton-talla-premium').forEach(b => b.classList.remove('is-active'));\n          this.classList.add('is-active');\n          \n          if (selectNativo) {\n            selectNativo.value = this.getAttribute('data-value');\n            selectNativo.dispatchEvent(new Event('change', { bubbles: true }));\n          }\n        };\n\n        cajaBotones.appendChild(btn);\n      }\n    }\n  }\n\n  // Ejecución en carga y en el editor de diseño\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', cargarTallasDesdeShopify);\n  } else {\n    cargarTallasDesdeShopify();\n  }\n  if (window.Shopify && window.Shopify.designMode) {\n    setInterval(cargarTallasDesdeShopify, 1000);\n  }\n})();\n</script>\n\n<style>\n  .boton-talla-premium {\n    display: inline-flex !important;\n    align-items: center !important;\n    justify-content: center !important;\n    min-width: 52px !important;\n    height: 48px !important;\n    padding: 0 16px !important;\n    background: #ffffff !important;\n    color: #121212 !important;\n    border: 1px solid #e2e8f0 !important;\n    border-radius: 4px !important;\n    font-size: 1.4rem !important;\n    font-weight: 500 !important;\n    cursor: pointer !important;\n    transition: all 0.15s ease !important;\n    font-family: inherit;\n  }\n  .boton-talla-premium:hover {\n    border-color: #121212 !important;\n  }\n  .boton-talla-premium.is-active {\n    border-color: #121212 !important;\n    background-color: #121212 !important;\n    color: #ffffff !important;\n  }\n</style>"
