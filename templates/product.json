        "custom_liquid_8qANKn": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% comment %} Detectamos la opción de las Tallas dinámicamente {% endcomment %}\n{%- assign talla_option = null -%}\n{%- for option in product.options_with_values -%}-\n  {%- assign name_downcase = option.name | downcase -%}\n  {%- if name_downcase == 'talla' or name_downcase == 'tallas' or name_downcase == 'size' or name_downcase == 'sizes' -%}\n    {%- assign talla_option = option -%}\n    {%- assign option_index = 'option' | append: forloop.index -%}\n    {%- break -%}\n  {%- endif -%}\n{%- endfor -%}\n\n{%- if talla_option -%}\n  <div class=\"custom-size-picker-wrapper\" style=\"margin: 2rem 0;\">\n    \n    {% comment %} ENCABEZADO: Título y enlace alineados {% endcomment %}\n    <div style=\"display: flex; justify-content: space-between; align-items: center; width: 100%; margin-bottom: 10px;\">\n      <span style=\"font-size: 1.4rem; font-weight: 500; color: #121212; letter-spacing: 0.4px;\">Talla</span>\n      \n      <a href=\"#tabla-tallas-modal\" style=\"display: inline-flex; align-items: center; gap: 6px; font-size: 1.3rem; color: #121212; text-decoration: underline; font-weight: 400; cursor: pointer; background: none; border: none; padding: 0;\">\n        <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"transform: rotate(-45deg); display: inline-block; vertical-align: middle;\">\n          <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line>\n          <line x1=\"9\" y1=\"12\" x2=\"9\" y2=\"15\"></line>\n          <line x1=\"14\" y1=\"12\" x2=\"14\" y2=\"15\"></line>\n        </svg>\n        Tabla de tallas\n      </a>\n    </div>\n\n    {% comment %} BOTONES: Mapeo automático de tus tallas de Shopify {% endcomment %}\n    <div class=\"custom-size-buttons\" style=\"display: flex; flex-wrap: wrap; gap: 10px;\">\n      {%- for value in talla_option.values -%}\n        {%- liquid\n          # Comprobamos si esta talla específica tiene stock en alguna variante\n          assign has_stock = false\n          for variant in product.variants\n            if variant[option_index] == value and variant.available\n              assign has_stock = true\n              break\n            endif\n          endfor\n        -%}\n\n        <button \n          type=\"button\"\n          class=\"size-btn {% if talla_option.selected_value == value %}is-active{% endif %} {% unless has_stock %}out-of-stock{% endunless %}\"\n          data-value=\"{{ value | escape }}\"\n          onclick=\"\n            (function(btn){\n              // 1. Cambiamos el diseño visual del botón seleccionado\n              var container = btn.closest('.custom-size-buttons');\n              container.querySelectorAll('.size-btn').forEach(b => b.classList.remove('is-active'));\n              btn.classList.add('is-active');\n\n              // 2. Buscamos el selector nativo de la página y le ordenamos cambiar la talla de verdad\n              var nativePicker = document.querySelector('variant-radios') || document.querySelector('variant-selects');\n              if (nativePicker) {\n                var nativeInput = nativePicker.querySelector('input[type=&quot;radio&quot;][value=&quot;' + btn.getAttribute('data-value') + '&quot;]') || nativePicker.querySelector('select option[value=&quot;' + btn.getAttribute('data-value') + '&quot;]');\n                if (nativeInput) {\n                  if (nativeInput.tagName === 'INPUT') {\n                    nativeInput.click();\n                  } else {\n                    nativeInput.parentElement.value = btn.getAttribute('data-value');\n                    nativeInput.parentElement.dispatchEvent(new Event('change', { bubbles: true }));\n                  }\n                }\n              }\n            })(this);\n          \"\n        >\n          {{ value }}\n        </button>\n      {%- endfor -%}\n    </div>\n  </div>\n\n  {% comment %} ESTILOS PRINCIPALES: Cuadrados y limpios {% endcomment %}\n  <style>\n    .size-btn {\n      display: inline-flex !important;\n      align-items: center !important;\n      justify-content: center !important;\n      min-width: 46px !important;\n      height: 46px !important;\n      padding: 0 14px !important;\n      background: #ffffff !important;\n      color: #121212 !important;\n      border: 1px solid #e2e8f0 !important;\n      border-radius: 4px !important;\n      font-size: 1.4rem !important;\n      font-weight: 500 !important;\n      cursor: pointer !important;\n      transition: all 0.15s ease !important;\n    }\n    .size-btn:hover {\n      border-color: #121212 !important;\n    }\n    .size-btn.is-active {\n      border-color: #121212 !important;\n      background-color: #121212 !important;\n      color: #ffffff !important;\n    }\n    .size-btn.out-of-stock {\n      opacity: 0.4 !important;\n      text-decoration: line-through !important;\n    }\n  </style>\n{%- endif -%}"
          }
