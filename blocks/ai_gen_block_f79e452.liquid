{% doc %}
  @prompt
    Create a section with two images side by side, where each image has its own independent link/URL setting. The left image should link to a "women" category and the right image should link to a "men" category. Each image block must have: its own image picker, its own link field, its own optional text overlay (title and subtitle), and a button or clickable area that redirects to its respective URL. The two images should be equal width and displayed horizontally on desktop, stacked vertically on mobile.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-image-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-dual-image-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
  }

  .ai-dual-image-item-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-dual-image-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    text-decoration: none;
    width: 100%;
    height: 100%;
  }

  .ai-dual-image-img-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-dual-image-img-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-dual-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-dual-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-dual-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-dual-image-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.text_vertical_alignment }};
    align-items: {{ block.settings.text_horizontal_alignment }};
    padding: {{ block.settings.overlay_padding }}px;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 1;
  }

  .ai-dual-image-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
    text-align: {{ block.settings.text_horizontal_alignment }};
  }

  .ai-dual-image-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    text-align: {{ block.settings.text_horizontal_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-dual-image-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-dual-image-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-dual-image-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.8);
    }
  }
{% endstyle %}

<dual-image-block-{{ ai_gen_id }} class="ai-dual-image-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dual-image-wrapper-{{ ai_gen_id }}">
    <div class="ai-dual-image-item-{{ ai_gen_id }}">
      {% if block.settings.image_left_url != blank %}
        <a href="{{ block.settings.image_left_url }}" class="ai-dual-image-link-{{ ai_gen_id }}">
      {% endif %}
        <div class="ai-dual-image-img-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image_left %}
            <img
              src="{{ block.settings.image_left | image_url: width: 1000 }}"
              alt="{{ block.settings.image_left.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image_left.width }}"
              height="{{ block.settings.image_left.height }}"
              class="ai-dual-image-img-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-dual-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-dual-image-empty-state-{{ ai_gen_id }}">
                Add left image
              </div>
            </div>
          {% endif %}
          {% if block.settings.image_left_title != blank or block.settings.image_left_subtitle != blank %}
            <div class="ai-dual-image-overlay-{{ ai_gen_id }}">
              {% if block.settings.image_left_title != blank %}
                <h3 class="ai-dual-image-title-{{ ai_gen_id }}">{{ block.settings.image_left_title }}</h3>
              {% endif %}
              {% if block.settings.image_left_subtitle != blank %}
                <p class="ai-dual-image-subtitle-{{ ai_gen_id }}">{{ block.settings.image_left_subtitle }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% if block.settings.image_left_url != blank %}
        </a>
      {% endif %}
    </div>

    <div class="ai-dual-image-item-{{ ai_gen_id }}">
      {% if block.settings.image_right_url != blank %}
        <a href="{{ block.settings.image_right_url }}" class="ai-dual-image-link-{{ ai_gen_id }}">
      {% endif %}
        <div class="ai-dual-image-img-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image_right %}
            <img
              src="{{ block.settings.image_right | image_url: width: 1000 }}"
              alt="{{ block.settings.image_right.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image_right.width }}"
              height="{{ block.settings.image_right.height }}"
              class="ai-dual-image-img-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-dual-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-dual-image-empty-state-{{ ai_gen_id }}">
                Add right image
              </div>
            </div>
          {% endif %}
          {% if block.settings.image_right_title != blank or block.settings.image_right_subtitle != blank %}
            <div class="ai-dual-image-overlay-{{ ai_gen_id }}">
              {% if block.settings.image_right_title != blank %}
                <h3 class="ai-dual-image-title-{{ ai_gen_id }}">{{ block.settings.image_right_title }}</h3>
              {% endif %}
              {% if block.settings.image_right_subtitle != blank %}
                <p class="ai-dual-image-subtitle-{{ ai_gen_id }}">{{ block.settings.image_right_subtitle }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% if block.settings.image_right_url != blank %}
        </a>
      {% endif %}
    </div>
  </div>
</dual-image-block-{{ ai_gen_id }}>

<script>
  (function() {
    class DualImageBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('dual-image-block-{{ ai_gen_id }}', DualImageBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Dual image links",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Left image"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_left_url",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "image_left_title",
      "label": "Title",
      "default": "Women"
    },
    {
      "type": "text",
      "id": "image_left_subtitle",
      "label": "Subtitle",
      "default": "Shop the collection"
    },
    {
      "type": "header",
      "content": "Right image"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_right_url",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "image_right_title",
      "label": "Title",
      "default": "Men"
    },
    {
      "type": "text",
      "id": "image_right_subtitle",
      "label": "Subtitle",
      "default": "Shop the collection"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        },
        {
          "value": "4 / 3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "16 / 9",
          "label": "Wide (16:9)"
        },
        {
          "value": "3 / 4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "2 / 3",
          "label": "Tall (2:3)"
        }
      ],
      "default": "4 / 3"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between images (desktop)",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap between images (mobile)",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Text overlay"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_horizontal_alignment",
      "label": "Horizontal alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "overlay_padding",
      "label": "Overlay padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    }
  ],
  "presets": [
    {
      "name": "Dual image links"
    }
  ]
}
{% endschema %}
