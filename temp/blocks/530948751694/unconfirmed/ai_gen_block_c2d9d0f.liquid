{% doc %}
  @prompt
    Create a two-image side-by-side layout section with the following requirements:
    - On desktop: two images displayed side by side, each taking exactly 50% of the width, with no gaps, no borders, no padding, no margins between them
    - On mobile: two images stacked vertically, each taking 100% of the width, with no gaps, no borders, no padding, no margins between them
    - Both images must have the exact same height and width
    - Images should use object-fit: cover to fill their containers completely
    - No spacing, no borders, no box shadows anywhere
    - The section should be fully responsive
    - Allow the merchant to set each image independently via theme settings
    - The images should be full bleed with zero whitespace between them
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .ai-dual-image-container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
    width: 100%;
    gap: 0;
  }

  .ai-dual-image-item-{{ ai_gen_id }} {
    flex: 0 0 50%;
    margin: 0;
    padding: 0;
    border: none;
    box-shadow: none;
    position: relative;
    overflow: hidden;
  }

  .ai-dual-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    margin: 0;
    overflow: hidden;
  }

  .ai-dual-image-wrapper-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    margin: 0;
    padding: 0;
    border: none;
    display: block;
  }

  .ai-dual-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
  }

  .ai-dual-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  @media screen and (max-width: 749px) {
    .ai-dual-image-item-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }
  }
{% endstyle %}

<dual-images-{{ ai_gen_id }} class="ai-dual-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dual-image-container-{{ ai_gen_id }}">
    <div class="ai-dual-image-item-{{ ai_gen_id }}">
      <div class="ai-dual-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_left %}
          <img
            src="{{ block.settings.image_left | image_url: width: 1500 }}"
            alt="{{ block.settings.image_left.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_left.width }}"
            height="{{ block.settings.image_left.height }}"
          >
        {% else %}
          <div class="ai-dual-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-dual-image-item-{{ ai_gen_id }}">
      <div class="ai-dual-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_right %}
          <img
            src="{{ block.settings.image_right | image_url: width: 1500 }}"
            alt="{{ block.settings.image_right.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_right.width }}"
            height="{{ block.settings.image_right.height }}"
          >
        {% else %}
          <div class="ai-dual-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</dual-images-{{ ai_gen_id }}>

<script>
  (function() {
    class DualImages{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('dual-images-{{ ai_gen_id }}', DualImages{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Dual image layout",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left image"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Right image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "min": 50,
      "max": 150,
      "step": 10,
      "unit": "%",
      "label": "Image height",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Dual image layout"
    }
  ]
}
{% endschema %}
