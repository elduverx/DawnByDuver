{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet">

{%- style -%}
  @media screen and (max-width: 749px) {
    .collection-hero--with-image .collection-hero__inner {
      padding-bottom: calc({{ settings.media_shadow_vertical_offset | at_least: 0 }}px + 2rem);
    }
  }

  .collection-hero.collection-hero--with-image {
    padding: 0 !important;
    overflow: visible !important;
  }

  @media screen and (min-width: 990px) {
    .collection-hero.collection-hero--with-image {
      margin-top: 11rem !important;
    }
  }
  .collection-hero--with-image .collection-hero__inner {
    position: relative;
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .collection-hero--with-image .collection-hero__image-container {
    width: 100% !important;
    flex-basis: 100% !important;
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    min-height: 320px;
  }

  .collection-hero--with-image .collection-hero__image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .collection-hero--with-image .collection-hero__text-wrapper {
    position: absolute;
    left: 2rem;
    bottom: 1.5rem;
    z-index: 2;
    padding: 0 !important;
    margin: 0 !important;
    flex-basis: auto !important;
    max-width: none !important;
  }

  .collection-hero--with-image .collection-hero__title {
    margin: 0 !important;
    color: #ffffff;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2.2rem;
    font-weight: 500;
    text-transform: none;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
  }

  .collection-hero--with-image .collection-hero__kicker {
    display: block;
    margin: 0 0 0.6rem;
    color: #ffffff;
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
  }

  @media screen and (min-width: 750px) {
    .collection-hero--with-image .collection-hero__image-container {
      min-height: 460px;
    }

    .collection-hero--with-image .collection-hero__text-wrapper {
      left: 3rem;
      bottom: 2.5rem;
    }

    .collection-hero--with-image .collection-hero__title {
      font-size: 3.4rem;
    }

    .collection-hero--with-image .collection-hero__kicker {
      font-size: 1.3rem;
      margin-bottom: 0.8rem;
    }
  }
{%- endstyle -%}

<div class="collection-hero{% if section.settings.show_collection_image and collection.image %} collection-hero--with-image{% endif %} color-{{ section.settings.color_scheme }} gradient">
  <div class="collection-hero__inner page-width {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <div class="collection-hero__text-wrapper">
      {%- if section.settings.show_collection_image and collection.image and section.settings.kicker_text != blank -%}
        <span class="collection-hero__kicker">{{ section.settings.kicker_text | escape }}</span>
      {%- endif -%}
      <h1 class="collection-hero__title">
        <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
        {{- collection.title | escape -}}
      </h1>

      {%- if section.settings.show_collection_description -%}
        <div class="collection-hero__description rte">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_collection_image and collection.image -%}
      <div class="collection-hero__image-container media gradient">
        <picture>
          {%- if section.settings.mobile_image -%}
            <source
              media="(max-width: 749px)"
              srcset="
                {%- if section.settings.mobile_image.width >= 375 -%}{{ section.settings.mobile_image | image_url: width: 375 }} 375w,{%- endif -%}
                {%- if section.settings.mobile_image.width >= 750 -%}{{ section.settings.mobile_image | image_url: width: 750 }} 750w,{%- endif -%}
                {%- if section.settings.mobile_image.width >= 1125 -%}{{ section.settings.mobile_image | image_url: width: 1125 }} 1125w,{%- endif -%}
                {{ section.settings.mobile_image | image_url }} {{ section.settings.mobile_image.width }}w
              "
            >
          {%- endif -%}
          <img
            srcset="
              {%- if collection.image.width >= 750 -%}{{ collection.image | image_url: width: 750 }} 750w,{%- endif -%}
              {%- if collection.image.width >= 1070 -%}{{ collection.image | image_url: width: 1070 }} 1070w,{%- endif -%}
              {%- if collection.image.width >= 1500 -%}{{ collection.image | image_url: width: 1500 }} 1500w,{%- endif -%}
              {%- if collection.image.width >= 2000 -%}{{ collection.image | image_url: width: 2000 }} 2000w,{%- endif -%}
              {{ collection.image | image_url }} {{ collection.image.width }}w
            "
            sizes="100vw"
            src="{{ collection.image | image_url: width: 1500 }}"
            alt="{{ collection.image.alt | escape }}"
            width="{{ collection.image.width }}"
            height="{{ collection.image.height }}"
          >
        </picture>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label"
    },
    {
      "type": "text",
      "id": "kicker_text",
      "default": "HOMBRE",
      "label": "Texto pequeño encima del título (solo con imagen de colección)"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Imagen versión móvil (opcional, recomendado formato vertical/cuadrado)"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
