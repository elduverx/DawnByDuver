<style>
  .combina-section {
    padding: 60px 80px;
    text-align: center;
  }
  .combina-eyebrow {
    font-size: 1.1rem;
    letter-spacing: 0.2em;
    color: #c9b99a;
    margin-bottom: 12px;
    text-transform: uppercase;
  }
  .combina-titulo {
    font-size: 3.5rem;
    font-weight: 400;
    font-family: Georgia, serif;
    margin-bottom: 40px;
    color: #121212;
    text-transform: none;
  }
  .combina-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 40px;
  }
  .combina-card {
    text-align: left;
  }
  .combina-card a {
    display: block;
    overflow: hidden;
  }
  .combina-card img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 0.3s ease;
  }
  .combina-card a:hover img {
    transform: scale(1.03);
  }
  .combina-card-info {
    padding: 12px 0 0 0;
  }
  .combina-card-titulo {
    font-size: 1.2rem;
    color: #121212;
    margin: 0 0 6px 0;
    font-weight: 400;
  }
  .combina-precios {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .combina-card-precio-original {
    font-size: 1.2rem;
    color: #9ca3af;
    text-decoration: line-through;
  }
  .combina-card-precio {
    font-size: 1.3rem;
    font-weight: 600;
    color: #121212;
  }
  .combina-btn-wrapper {
    margin-top: 20px;
  }
  .combina-btn {
    display: inline-block;
    background: #121212;
    color: #ffffff;
    padding: 16px 48px;
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    text-decoration: none;
    font-family: 'Assistant', sans-serif;
  }
  .combina-btn:hover {
    background: #333333;
    color: #ffffff;
  }
  @media screen and (max-width: 749px) {
    .combina-section {
      padding: 40px