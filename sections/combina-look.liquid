<style>
  .combina-section {
    padding: 40px 180px;
    text-align: center;
  }
  }
  .combina-eyebrow {
    font-size: 1.1rem;
    letter-spacing: 0.2em;
    color: #c9b99a;
    margin-bottom: 12px;
    text-transform: uppercase;
  }
  .combina-titulo {
    font-size: 3.5rem;
    font-weight: 400;
    font-family: Georgia, serif;
    margin-bottom: 40px;
    color: #121212;
    text-transform: none;
  }
  .combina-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 40px;
  }
  .combina-card { text-align: left; }
  .combina-card a { display: block; overflow: hidden; }
  .combina-card img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 0.3s ease;
  }
  .combina-card a:hover img { transform: scale(1.03); }
  .combina-card-info { padding: 12px 0 0 0; }
  .combina-card-titulo {
    font-size: 1.2rem;
    color: #121212;
    margin: 0 0 6px 0;
    font-weight: 400;
  }
  .combina-precios { display: flex; align-items: center; gap: 8px; }
  .combina-card-precio-original {
    font-size: 1.2rem;
    color: #9ca3af;
    text-decoration: line-through;
  }
  .combina-card-precio { font-size: 1.3rem; font-weight: 600; color: #121212; }
  .combina-btn-wrapper { margin-top: 20px; }
  .combina-btn {
    display: inline-block;
    background: #121212;
    color: #ffffff;
    padding: 16px 48px;
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    text-decoration: none;
    font-family: 'Assistant', sans-serif;
  }
  .combina-btn:hover { background: #333333; color: #ffffff; }
  @media screen and (max-width: 749px) {
    .combina-section { padding: 40px 16px; }
    .combina-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
    .combina-titulo { font-size: 2.2rem; }
  }
</style>

<div class="combina-section">
  <p class="combina-eyebrow">{{ section.settings.eyebrow }}</p>
  <h2 class="combina-titulo">{{ section.settings.titulo }}</h2>
  <div class="combina-grid">
    {%- for block in section.blocks -%}
      {%- assign prod = block.settings.producto -%}
      {%- if prod != blank -%}
        <div class="combina-card">
          <a href="{{ prod.url }}">
            {%- if prod.featured_image != blank -%}
              <img src="{{ prod.featured_image | image_url: width: 600 }}" alt="{{ prod.title }}">
            {%- else -%}
              <div style="width:100%;aspect-ratio:3/4;background:#f3f3f3;"></div>
            {%- endif -%}
          </a>
          <div class="combina-card-info">
            <p class="combina-card-titulo">{{ prod.title }}</p>
            <div class="combina-precios">
              {%- if prod.compare_at_price > prod.price -%}
                <span class="combina-card-precio-original">{{ prod.compare_at_price | money }}</span>
              {%- endif -%}
              <span class="combina-card-precio">{{ prod.price | money }}</span>
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  <div class="combina-btn-wrapper">
    <a href="{{ section.settings.url_ver_todo }}" class="combina-btn">{{ section.settings.texto_boton }}</a>
  </div>
</div>

{% schema %}
{
  "name": "Combina tu look",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "TAMBIÉN TE PUEDE INTERESAR"
    },
    {
      "type": "text",
      "id": "titulo",
      "label": "Título",
      "default": "Combina tu look"
    },
    {
      "type": "text",
      "id": "texto_boton",
      "label": "Texto botón",
      "default": "Ver todo"
    },
    {
      "type": "url",
      "id": "url_ver_todo",
      "label": "Enlace botón Ver todo",
      "default": "/collections/all"
    }
  ],
  "blocks": [
    {
      "type": "producto",
      "name": "Producto",
      "settings": [
        {
          "type": "product",
          "id": "producto",
          "label": "Producto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Combina tu look",
      "blocks": [
        { "type": "producto" },
        { "type": "producto" },
        { "type": "producto" },
        { "type": "producto" }
      ]
    }
  ]
}
{% endschema %}