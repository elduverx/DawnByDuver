{%- style -%}
  .editorial-banner {
    padding: 40px 0;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }
  .editorial-banner__image {
    width: 900px;
    max-width: calc(100% - 80px);
    height: 480px;
    object-fit: cover;
    display: block;
  }
  .editorial-banner__text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: #fff;
    text-shadow: 0 1px 6px rgba(0,0,0,0.3);
    width: 100%;
    padding: 0 20px;
  }
  .editorial-banner__eyebrow {
    display: block;
    font-family: 'Assistant', sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 12px;
    opacity: 0.9;
  }
  .editorial-banner__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .editorial-banner__subtitle {
    font-family: 'Assistant', sans-serif;
    font-size: 14px;
    font-weight: 300;
    line-height: 1.6;
    max-width: 420px;
    margin: 0 auto;
    opacity: 0.9;
  }
  @media screen and (max-width: 749px) {
    .editorial-banner__image {
      max-width: calc(100% - 32px);
      height: 220px;
    }
    .editorial-banner__title {
      font-size: clamp(1.8rem, 6vw, 2.5rem);
    }
    .editorial-banner__subtitle {
      font-size: 12px;
    }
  }
{%- endstyle -%}

<div class="editorial-banner">
  {%- if section.settings.image != blank -%}
    {{
      section.settings.image
      | image_url: width: 1200
      | image_tag: class: 'editorial-banner__image', loading: 'lazy'
    }}
  {%- endif -%}
  <div class="editorial-banner__text">
    <span class="editorial-banner__eyebrow">— MUY PRONTO</span>
    <h2 class="editorial-banner__title">Próxima apertura</h2>
    <p class="editorial-banner__subtitle">Estamos preparando algo especial para ti. Vive la experiencia Vela Madrid más cerca que nunca.</p>
  </div>
</div>

{% schema %}
{
  "name": "Banner editorial",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    }
  ],
  "presets": [{ "name": "Banner editorial" }]
}
{% endschema %}